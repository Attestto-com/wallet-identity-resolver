{
  "name": "identity-resolver",
  "version": "0.2.1",
  "description": "Identity middleware — resolve DIDs, domains, SBTs, credentials, and compliance status from any wallet address",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js",
      "require": "./dist/providers/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/providers/index.ts --format esm,cjs --dts --clean",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "did",
    "wallet",
    "identity",
    "resolver",
    "sbt",
    "verifiable-credentials",
    "solana",
    "ethereum",
    "sns",
    "ens",
    "civic",
    "ssi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Attestto-com/identity-resolver.git"
  },
  "author": "Eduardo Chongkan",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
