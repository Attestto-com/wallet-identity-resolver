{
  "name": "wallet-identity-resolver",
  "version": "0.1.0",
  "description": "Pluggable on-chain identity discovery — resolve DIDs, SBTs, and credentials from any wallet address",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "require": "./dist/providers/index.cjs",
      "types": "./dist/providers/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/providers/index.ts --format esm,cjs --dts --clean",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "did",
    "wallet",
    "identity",
    "resolver",
    "sbt",
    "verifiable-credentials",
    "solana",
    "ethereum",
    "sns",
    "ens",
    "civic",
    "ssi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chongkan/wallet-identity-resolver.git"
  },
  "author": "Eduardo Chongkan",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
